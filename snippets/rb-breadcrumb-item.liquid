{%- comment -%}
  Rough Bobber — single breadcrumb crumb.
  Renders one <li> for sections/rb-breadcrumb.liquid with schema.org ListItem
  microdata. Pass a url to make it a link; leave url blank (or current: true)
  to render the final, non-linked current crumb.

  Params:
    label    {String}  visible text (required)
    url      {String}  link target; blank = current crumb
    position {Number}  1-based position in the BreadcrumbList (required)
    current  {Boolean} force the current (non-link) style
{%- endcomment -%}
{%- liquid
  assign is_current = false
  if current == true or url == blank
    assign is_current = true
  endif
-%}
<li
  class="rb-breadcrumb__item{% if is_current %} rb-breadcrumb__item--current{% endif %}"
  itemprop="itemListElement"
  itemscope
  itemtype="http://schema.org/ListItem"
  {% if is_current %}aria-current="page"{% endif %}
>
  {%- if is_current -%}
    <span class="rb-breadcrumb__current" title="{{ label | strip_html | escape }}" itemprop="name">{{ label }}</span>
  {%- else -%}
    <a class="rb-breadcrumb__link" href="{{ url }}" title="{{ label | strip_html | escape }}" itemprop="item">
      <span itemprop="name">{{ label }}</span>
    </a>
  {%- endif -%}
  <meta itemprop="position" content="{{ position }}">
</li>