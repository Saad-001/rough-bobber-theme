{%- comment -%}
  Product carousel — Rough Bobber ("Shop T-Shirts")
  Horizontal, swipeable carousel of products from a chosen collection, with a
  heading, a "View all" link, prev/next arrows, price and colour swatches.

  Conventions (conventions.md): static CSS in assets/rb-product-carousel.css;
  only Liquid-driven values in the {% style %} block; color_scheme; Dawn
  .section-{id}-padding; .page-width; brand fonts.
{%- endcomment -%}

{{ 'rb-product-carousel.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign uid = 'rb-product-carousel-' | append: section.id
  assign collection = collections[s.collection]
  assign products = collection.products

  case s.image_ratio
    when 'portrait'
      assign ratio = '4 / 5'
      assign fit = 'cover'
    when 'landscape'
      assign ratio = '4 / 3'
      assign fit = 'cover'
    when 'contain'
      assign ratio = '1 / 1'
      assign fit = 'contain'
    else
      assign ratio = '1 / 1'
      assign fit = 'cover'
  endcase

  assign view_all_url = s.button_link
  if view_all_url == blank
    assign view_all_url = collection.url
  endif
-%}

{%- style -%}
  #{{ uid }} {
    --rb-pc-per: {{ s.products_per_row }};
    --rb-pc-ratio: {{ ratio }};
    --rb-pc-fit: {{ fit }};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div id="{{ uid }}" class="rb-pc color-{{ s.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {%- if s.heading != blank or s.show_view_all -%}
      <div class="rb-pc__header">
        {%- if s.heading != blank -%}
          <h2 class="rb-pc__heading">{{ s.heading }}</h2>
        {%- endif -%}
        {%- if s.show_view_all and view_all_url != blank -%}
          <a class="rb-pc__viewall" href="{{ view_all_url }}">
            {{- s.view_all_label | default: 'View all' -}}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="rb-pc__viewport">
      <button type="button" class="rb-pc__arrow rb-pc__arrow--prev" aria-label="{{ 'general.slider.previous_slide' | t }}" disabled>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>

      <div class="rb-pc__track" role="list">
        {%- if products.size > 0 -%}
          {%- for product in products limit: s.products_to_show -%}
            {%- liquid
              assign cap = product.compare_at_price
              assign on_sale = false
              if cap > product.price and product.available
                assign on_sale = true
              endif
            -%}
            <a class="rb-pc__card" href="{{ product.url }}" role="listitem">
              <div class="rb-pc__media">
                {%- if product.featured_media -%}
                  <img
                    class="rb-pc__img"
                    src="{{ product.featured_media | image_url: width: 600 }}"
                    srcset="
                      {{ product.featured_media | image_url: width: 300 }} 300w,
                      {{ product.featured_media | image_url: width: 450 }} 450w,
                      {{ product.featured_media | image_url: width: 600 }} 600w,
                      {{ product.featured_media | image_url: width: 900 }} 900w"
                    sizes="(max-width: 749px) 45vw, 18vw"
                    width="{{ product.featured_media.width }}"
                    height="{{ product.featured_media.height }}"
                    alt="{{ product.featured_media.alt | default: product.title | escape }}"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'product-apparel-1' | placeholder_svg_tag: 'rb-pc__placeholder-svg' }}
                {%- endif -%}

                {%- if s.show_badges -%}
                  {%- if product.available == false -%}
                    <span class="rb-pc__badge rb-pc__badge--soldout">{{ 'products.product.sold_out' | t }}</span>
                  {%- elsif on_sale -%}
                    <span class="rb-pc__badge">{{ 'products.product.on_sale' | t }}</span>
                  {%- endif -%}
                {%- endif -%}
              </div>

              <div class="rb-pc__info">
                <h3 class="rb-pc__title">{{ product.title }}</h3>

                <div class="rb-pc__price">
                  {%- if product.price_varies -%}
                    {%- assign money = product.price | money -%}
                    {%- if settings.currency_code_enabled -%}{%- assign money = product.price | money_with_currency -%}{%- endif -%}
                    {{ 'products.product.price.from_price_html' | t: price: money }}
                  {%- elsif on_sale -%}
                    <s>{% if settings.currency_code_enabled %}{{ cap | money_with_currency }}{% else %}{{ cap | money }}{% endif %}</s>
                    <span class="rb-pc__price--sale">{% if settings.currency_code_enabled %}{{ product.price | money_with_currency }}{% else %}{{ product.price | money }}{% endif %}</span>
                  {%- else -%}
                    {% if settings.currency_code_enabled %}{{ product.price | money_with_currency }}{% else %}{{ product.price | money }}{% endif %}
                  {%- endif -%}
                </div>

                {%- if s.show_swatches -%}
                  {%- assign sw_total = 0 -%}
                  {%- for option in product.options_with_values -%}
                    {%- for value in option.values -%}
                      {%- if value.swatch -%}{%- assign sw_total = sw_total | plus: 1 -%}{%- endif -%}
                    {%- endfor -%}
                  {%- endfor -%}
                  {%- if sw_total > 0 -%}
                    <div class="rb-pc__swatches">
                      {%- assign sw_max = 5 -%}
                      {%- assign sw_i = 0 -%}
                      {%- for option in product.options_with_values -%}
                        {%- for value in option.values -%}
                          {%- if value.swatch and sw_i < sw_max -%}
                            {%- assign sw_i = sw_i | plus: 1 -%}
                            {%- liquid
                              if value.swatch.image
                                assign sv = value.swatch.image | image_url: width: 40
                                assign sv = 'url(' | append: sv | append: ')'
                              elsif value.swatch.color
                                assign sv = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                              else
                                assign sv = '#cccccc'
                              endif
                            -%}
                            <span class="rb-pc__swatch" style="--rb-swatch: {{ sv }};" title="{{ value | escape }}"></span>
                          {%- endif -%}
                        {%- endfor -%}
                      {%- endfor -%}
                      {%- if sw_total > sw_max -%}
                        <span class="rb-pc__swatch-more">+{{ sw_total | minus: sw_max }}</span>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..5) -%}
            <div class="rb-pc__card" role="listitem">
              <div class="rb-pc__media">
                {{ 'product-' | append: i | placeholder_svg_tag: 'rb-pc__placeholder-svg' }}
              </div>
              <div class="rb-pc__info">
                <h3 class="rb-pc__title">{{ 'onboarding.product_title' | t }}</h3>
                <div class="rb-pc__price">{{ 1999 | money }}</div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <button type="button" class="rb-pc__arrow rb-pc__arrow--next" aria-label="{{ 'general.slider.next_slide' | t }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('{{ uid }}');
    if (!root) return;
    var track = root.querySelector('.rb-pc__track');
    var prev = root.querySelector('.rb-pc__arrow--prev');
    var next = root.querySelector('.rb-pc__arrow--next');
    if (!track) return;

    function step() {
      var card = track.querySelector('.rb-pc__card');
      if (!card) return track.clientWidth;
      var gap = parseInt(getComputedStyle(track).columnGap || getComputedStyle(track).gap, 10) || 0;
      return card.getBoundingClientRect().width + gap;
    }

    function update() {
      var max = track.scrollWidth - track.clientWidth - 1;
      if (prev) prev.disabled = track.scrollLeft <= 1;
      if (next) next.disabled = track.scrollLeft >= max;
    }

    if (next) next.addEventListener('click', function () { track.scrollBy({ left: step(), behavior: 'smooth' }); });
    if (prev) prev.addEventListener('click', function () { track.scrollBy({ left: -step(), behavior: 'smooth' }); });
    track.addEventListener('scroll', function () { window.requestAnimationFrame(update); }, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();

    // Pointer drag-to-scroll (mouse). Touch uses native scrolling.
    var down = false, startX = 0, startLeft = 0, moved = false;
    root.classList.add('rb-pc--draggable');
    track.addEventListener('pointerdown', function (e) {
      if (e.pointerType === 'touch') return;
      down = true; moved = false;
      startX = e.clientX; startLeft = track.scrollLeft;
      try { track.setPointerCapture(e.pointerId); } catch (err) {}
    });
    track.addEventListener('pointermove', function (e) {
      if (!down) return;
      var dx = e.clientX - startX;
      if (Math.abs(dx) > 4) { moved = true; root.classList.add('is-dragging'); }
      track.scrollLeft = startLeft - dx;
    });
    function release(e) {
      if (!down) return;
      down = false;
      root.classList.remove('is-dragging');
      try { track.releasePointerCapture(e.pointerId); } catch (err) {}
    }
    track.addEventListener('pointerup', release);
    track.addEventListener('pointercancel', release);
    track.addEventListener('click', function (e) { if (moved) { e.preventDefault(); moved = false; } }, true);
  })();
</script>

{% schema %}
{
  "name": "t:sections.rb_product_carousel.name",
  "tag": "section",
  "class": "section-rb-product-carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.rb_product_carousel.settings.heading.label",
      "default": "Shop T-Shirts"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.rb_product_carousel.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.rb_product_carousel.settings.products_to_show.label",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 10
    },
    {
      "type": "range",
      "id": "products_per_row",
      "label": "t:sections.rb_product_carousel.settings.products_per_row.label",
      "info": "t:sections.rb_product_carousel.settings.products_per_row.info",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 5
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.rb_product_carousel.settings.image_ratio.label",
      "options": [
        { "value": "square", "label": "t:sections.rb_product_carousel.settings.image_ratio.options__square" },
        { "value": "portrait", "label": "t:sections.rb_product_carousel.settings.image_ratio.options__portrait" },
        { "value": "landscape", "label": "t:sections.rb_product_carousel.settings.image_ratio.options__landscape" },
        { "value": "contain", "label": "t:sections.rb_product_carousel.settings.image_ratio.options__contain" }
      ],
      "default": "square"
    },
    {
      "type": "header",
      "content": "t:sections.rb_product_carousel.settings.header_card.content"
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "t:sections.rb_product_carousel.settings.show_swatches.label",
      "info": "t:sections.rb_product_carousel.settings.show_swatches.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "t:sections.rb_product_carousel.settings.show_badges.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.rb_product_carousel.settings.header_view_all.content"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "t:sections.rb_product_carousel.settings.show_view_all.label",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "t:sections.rb_product_carousel.settings.view_all_label.label",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.rb_product_carousel.settings.button_link.label",
      "info": "t:sections.rb_product_carousel.settings.button_link.info"
    },
    {
      "type": "header",
      "content": "t:sections.rb_product_carousel.settings.header_colors.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "t:sections.rb_product_carousel.presets.name"
    }
  ]
}
{% endschema %}
