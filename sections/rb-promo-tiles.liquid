      "id": "text_color",
      "label": "t:sections.rb_promo_tiles.settings.text_color.label"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "t:sections.rb_promo_tiles.settings.button_bg.label"
    },
    {
      "type": "color",
      "id": "button_text_color",
