          "content": "t:sections.rb_promo_tiles.blocks.tile.settings.header_text.content"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "t:sections.rb_promo_tiles.blocks.tile.settings.eyebrow.label"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.rb_promo_tiles.blocks.tile.settings.heading.label"
        },
