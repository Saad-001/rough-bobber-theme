          "type": "header",
          "content": "t:sections.rb_promo_tiles.blocks.tile.settings.header_link.content"
        },
        {
          "type": "url",
          "id": "tile_link",
          "label": "t:sections.rb_promo_tiles.blocks.tile.settings.tile_link.label",
