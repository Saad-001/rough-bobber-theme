        { "value": "center", "label": "t:sections.rb_promo_tiles.settings.content_vertical.options__center" },
        { "value": "bottom", "label": "t:sections.rb_promo_tiles.settings.content_vertical.options__bottom" }
      ],
      "default": "bottom"
    },
    {
      "type": "select",
      "id": "text_align",
