          "type": "richtext",
          "id": "text",
          "label": "t:sections.rb_promo_tiles.blocks.tile.settings.text.label"
        },
        {
          "type": "header",
          "content": "t:sections.rb_promo_tiles.blocks.tile.settings.header_button.content"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:sections.rb_promo_tiles.blocks.tile.settings.button_label.label",
          "info": "t:sections.rb_promo_tiles.blocks.tile.settings.button_label.info"
        },
        {
          "type": "url",
