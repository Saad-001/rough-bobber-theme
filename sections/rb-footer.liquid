{%- comment -%}
  Footer — Rough Bobber
  Brand block (logo / tagline / social) + "Stay in the loop" newsletter +
  menu columns (linklist blocks) + bottom bar (copyright + shop policies).

  Conventions (conventions.md): static CSS in assets/rb-footer.css; only
  Liquid-driven values in the {% style %} block; color_scheme; Dawn
  .section-{id}-padding; .page-width; brand fonts.
{%- endcomment -%}

{{ 'rb-footer.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign uid = 'rb-footer-' | append: section.id
  assign footer_logo = s.logo | default: settings.logo

  assign menu_blocks = section.blocks | where: 'type', 'menu'
-%}

{%- style -%}
  #{{ uid }} {
    --rb-footer-logo-width: {{ s.logo_width }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer id="{{ uid }}" class="rb-footer color-{{ s.color_scheme }} gradient" role="contentinfo">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="rb-footer__top">
      <div class="rb-footer__brand">
        {%- if s.logo_style == 'image' and footer_logo != blank -%}
          {%- assign logo_w = s.logo_width | times: 2 -%}
          <img
            class="rb-footer__logo-img"
            src="{{ footer_logo | image_url: width: logo_w }}"
            width="{{ footer_logo.width }}"
            height="{{ footer_logo.height }}"
            alt="{{ shop.name | escape }}"
            loading="lazy"
          >
        {%- else -%}
          <p class="rb-footer__logo-text">{{ shop.name }}</p>
        {%- endif -%}

        {%- if s.tagline != blank -%}
          <p class="rb-footer__tagline">{{ s.tagline }}</p>
        {%- endif -%}

        {%- if s.show_social -%}
          <ul class="rb-footer__social">
            {%- if settings.social_instagram_link != blank -%}
              <li><a href="{{ settings.social_instagram_link }}" aria-label="Instagram" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
              </a></li>
            {%- endif -%}
            {%- if settings.social_facebook_link != blank -%}
              <li><a href="{{ settings.social_facebook_link }}" aria-label="Facebook" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14 9h2.5V6H14c-1.9 0-3 1.3-3 3v1.5H9V13h2v7h3v-7h2.2l.3-2.5H14V9.4c0-.3.2-.4.5-.4z"/></svg>
              </a></li>
            {%- endif -%}
            {%- if settings.social_pinterest_link != blank -%}
              <li><a href="{{ settings.social_pinterest_link }}" aria-label="Pinterest" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-3.6 19.3c-.1-.8-.2-2 0-2.9l1.2-5s-.3-.6-.3-1.5c0-1.4.8-2.4 1.8-2.4.9 0 1.3.6 1.3 1.4 0 .9-.5 2.2-.8 3.4-.2 1 .5 1.8 1.5 1.8 1.8 0 3.1-1.9 3.1-4.6 0-2.4-1.7-4.1-4.2-4.1a4.3 4.3 0 0 0-4.5 4.3c0 .9.3 1.4.8 2 .1.2.1.3 0 .5l-.3 1c0 .3-.2.4-.5.2-1.2-.5-1.8-2-1.8-3.5C5.4 8.5 7.3 6 11.6 6c3.4 0 5.7 2.5 5.7 5.1 0 3.5-2 6.2-4.9 6.2-1 0-1.9-.5-2.2-1.1l-.6 2.3c-.2.8-.7 1.7-1 2.3A10 10 0 1 0 12 2z"/></svg>
              </a></li>
            {%- endif -%}
            {%- if settings.social_tiktok_link != blank -%}
              <li><a href="{{ settings.social_tiktok_link }}" aria-label="TikTok" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 3c.3 2 1.5 3.5 3.5 3.8V9.5c-1.3 0-2.5-.4-3.5-1v6.1A5.6 5.6 0 1 1 10.4 9v2.8a2.8 2.8 0 1 0 2 2.7V3h3.6z"/></svg>
              </a></li>
            {%- endif -%}
            {%- if settings.social_youtube_link != blank -%}
              <li><a href="{{ settings.social_youtube_link }}" aria-label="YouTube" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 8.2a2.6 2.6 0 0 0-1.8-1.8C18.6 6 12 6 12 6s-6.6 0-8.2.4A2.6 2.6 0 0 0 2 8.2 27 27 0 0 0 1.6 12 27 27 0 0 0 2 15.8a2.6 2.6 0 0 0 1.8 1.8C5.4 18 12 18 12 18s6.6 0 8.2-.4a2.6 2.6 0 0 0 1.8-1.8c.3-1.3.4-2.5.4-3.8s-.1-2.5-.4-3.8zM10 15V9l5.2 3z"/></svg>
              </a></li>
            {%- endif -%}
            {%- if settings.social_twitter_link != blank -%}
              <li><a href="{{ settings.social_twitter_link }}" aria-label="X" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 3h3l-6.6 7.6L22 21h-6.1l-4.3-5.6L6.5 21H3.5l7-8L2.3 3h6.2l3.9 5.1L17.5 3zm-1.1 16h1.7L7.7 4.8H5.9z"/></svg>
              </a></li>
            {%- endif -%}
          </ul>
        {%- endif -%}
      </div>

      {%- if s.show_newsletter -%}
        <div class="rb-footer__newsletter">
          {%- if s.newsletter_heading != blank -%}
            <h2 class="rb-footer__heading">{{ s.newsletter_heading }}</h2>
          {%- endif -%}
          {%- if s.newsletter_text != blank -%}
            <p class="rb-footer__newsletter-text">{{ s.newsletter_text }}</p>
          {%- endif -%}

          {%- form 'customer' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="rb-footer__form">
              <input
                type="email"
                name="contact[email]"
                class="rb-footer__input"
                value="{{ form.email }}"
                aria-label="{{ 'newsletter.label' | t }}"
                placeholder="{{ s.newsletter_placeholder | default: 'Enter your email' | escape }}"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                required
              >
              <button type="submit" class="rb-footer__submit" name="commit">
                {{- s.newsletter_button_label | default: 'Subscribe' -}}
              </button>
            </div>
            {%- if form.posted_successfully? -%}
              <p class="rb-footer__newsletter-success">{{ 'newsletter.success' | t }}</p>
            {%- elsif form.errors -%}
              <p class="rb-footer__newsletter-error">
                {{ form.errors.translated_fields['email'] | capitalize }}
                {{ form.errors.messages['email'] }}
              </p>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

      {%- if menu_blocks.size > 0 -%}
        <div class="rb-footer__menus">
          {%- for block in menu_blocks -%}
            {%- assign linklist = linklists[block.settings.menu] -%}
            <div class="rb-footer__col" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="rb-footer__col-title">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if linklist.links.size > 0 -%}
                <ul class="rb-footer__links">
                  {%- for link in linklist.links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="rb-footer__bottom">
      <p class="rb-footer__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}{% if s.copyright_text != blank %} · {{ s.copyright_text }}{% endif %}
      </p>
      {%- if s.show_policies and shop.policies.size > 0 -%}
        <ul class="rb-footer__policies">
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              <li><a href="{{ policy.url }}">{{ policy.title }}</a></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.rb_footer.name",
  "tag": "footer",
  "class": "section-rb-footer",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.rb_footer.settings.header_brand.content"
    },
    {
      "type": "select",
      "id": "logo_style",
      "label": "t:sections.rb_footer.settings.logo_style.label",
      "info": "t:sections.rb_footer.settings.logo_style.info",
      "options": [
        {
          "value": "text",
          "label": "t:sections.rb_footer.settings.logo_style.options__1.label"
        },
        {
          "value": "image",
          "label": "t:sections.rb_footer.settings.logo_style.options__2.label"
        }
      ],
      "default": "text"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:sections.rb_footer.settings.logo.label",
      "info": "t:sections.rb_footer.settings.logo.info"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "t:sections.rb_footer.settings.logo_width.label",
      "min": 80,
      "max": 280,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "t:sections.rb_footer.settings.tagline.label",
      "default": "Built by ride. Worn for life."
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "t:sections.rb_footer.settings.show_social.label",
      "info": "t:sections.rb_footer.settings.show_social.info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.rb_footer.settings.header_newsletter.content"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "t:sections.rb_footer.settings.show_newsletter.label",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "t:sections.rb_footer.settings.newsletter_heading.label",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "t:sections.rb_footer.settings.newsletter_text.label",
      "default": "Get updates on new drops, stories and more."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "t:sections.rb_footer.settings.newsletter_placeholder.label",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "newsletter_button_label",
      "label": "t:sections.rb_footer.settings.newsletter_button_label.label",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "t:sections.rb_footer.settings.header_bottom.content"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "t:sections.rb_footer.settings.copyright_text.label",
      "default": "All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_policies",
      "label": "t:sections.rb_footer.settings.show_policies.label",
      "info": "t:sections.rb_footer.settings.show_policies.info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.rb_footer.settings.header_colors.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "t:sections.rb_footer.blocks.menu.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.rb_footer.blocks.menu.settings.heading.label",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:sections.rb_footer.blocks.menu.settings.menu.label",
          "default": "footer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.rb_footer.presets.name",
      "blocks": [
        { "type": "menu", "settings": { "heading": "Shop" } },
        { "type": "menu", "settings": { "heading": "Company" } },
        { "type": "menu", "settings": { "heading": "Help" } }
      ]
    }
  ]
}
{% endschema %}
