{%- comment -%}
  Hero Slideshow — Rough Bobber
  Full-screen slideshow that matches the Hero Banner look, with multiple
  slides (blocks).

  - Each slide can be an image OR a Shopify-hosted video.
  - Each slide can be made clickable (whole slide links) and/or carry a button.
  - Separate desktop / mobile artwork per image slide (mobile optional).
  - Auto-rotation (on/off + speed), navigation arrows (show/hide) and dots.
  - Fills the visible viewport height like the Hero Banner (svh-based, vh fallback).

  Conventions (conventions.md):
  - Static styles live in assets/rb-slideshow.css (loaded below); only Liquid-driven
    values are emitted in the {% style %} block.
  - Colours come from the section's color_scheme, with optional per-colour overrides.
  - Top/bottom padding uses Dawn's .section-{id}-padding pattern; side padding/width
    come from .page-width. Fonts are the brand stacks from rb-fonts.css.
{%- endcomment -%}

{{ 'rb-slideshow.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign uid = 'rb-slideshow-' | append: section.id

  case s.height
    when 'full'
      assign h = '100svh'
    when 'large'
      assign h = '78svh'
    when 'medium'
      assign h = '60svh'
  endcase

  assign overlay_alpha = s.overlay_opacity | divided_by: 100.0
  assign overlay_rgba = s.overlay_color | color_modify: 'alpha', overlay_alpha

  assign gradient_alpha = s.gradient_opacity | divided_by: 100.0
  assign gradient_rgba = '#000000' | color_modify: 'alpha', gradient_alpha

  assign slides = section.blocks
-%}

{%- style -%}
  #{{ uid }} {
    --rb-ss-h: {{ h }};
    --rb-ss-overlay: {{ overlay_rgba }};
    --rb-ss-gradient: {{ gradient_rgba }};
    --rb-ss-content-width: {{ s.content_width }}px;
    {%- if s.heading_color != blank %}--rb-ss-heading: {{ s.heading_color }};{% endif -%}
    {%- if s.text_color != blank %}--rb-ss-text: {{ s.text_color }};{% endif -%}
    {%- if s.button_bg != blank %}--rb-ss-btn-bg: {{ s.button_bg }};{% endif -%}
    {%- if s.button_text_color != blank %}--rb-ss-btn-text: {{ s.button_text_color }};{% endif -%}
    {%- if s.button_2_bg != blank %}--rb-ss-btn2-bg: {{ s.button_2_bg }};{% endif -%}
    {%- if s.button_2_text_color != blank %}--rb-ss-btn2-text: {{ s.button_2_text_color }};{% endif -%}
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  id="{{ uid }}"
  class="rb-slideshow color-{{ s.color_scheme }} gradient"
  data-count="{{ slides.size }}"
  data-valign="{{ s.content_vertical }}"
  data-align="{{ s.text_align }}"
  data-autoplay="{% if s.autoplay %}true{% else %}false{% endif %}"
  data-speed="{{ s.autoplay_speed | times: 1000 }}"
  data-subtract="{% if s.subtract_header %}true{% else %}false{% endif %}"
  data-btn-fullwidth="{% if s.button_full_width_mobile %}true{% else %}false{% endif %}"
>
  <div class="rb-slideshow__track">
    {%- for block in slides -%}
      {%- liquid
        assign b = block.settings
        assign desk = b.image
        assign mob = b.image_mobile
        if mob == blank
          assign mob = desk
        endif
        assign is_video = false
        if b.media_type == 'video' and b.video != blank
          assign is_video = true
        endif
        assign has_button = false
        if b.button_label != blank
          assign has_button = true
        endif
        assign has_button_2 = false
        if b.button_2_label != blank
          assign has_button_2 = true
        endif
      -%}

      <div class="rb-slideshow__slide{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        <div class="rb-slideshow__media">
          {%- if is_video -%}
            {{ b.video | video_tag: image_size: '1600x', loop: true, muted: true, controls: false, autoplay: false, preload: 'metadata' }}
          {%- elsif desk != blank -%}
            {%- assign d_alt = desk.alt | default: b.heading | escape -%}
            <picture>
              {%- if mob != blank -%}
                <source
                  media="(max-width: 749px)"
                  srcset="
                    {{ mob | image_url: width: 450 }} 450w,
                    {{ mob | image_url: width: 600 }} 600w,
                    {{ mob | image_url: width: 750 }} 750w,
                    {{ mob | image_url: width: 900 }} 900w,
                    {{ mob | image_url: width: 1100 }} 1100w,
                    {{ mob | image_url: width: 1400 }} 1400w"
                  sizes="100vw"
                >
              {%- endif -%}
              <img
                class="rb-slideshow__img"
                style="object-position: {{ b.focal_point }};"
                src="{{ desk | image_url: width: 1500 }}"
                srcset="
                  {{ desk | image_url: width: 750 }} 750w,
                  {{ desk | image_url: width: 1100 }} 1100w,
                  {{ desk | image_url: width: 1500 }} 1500w,
                  {{ desk | image_url: width: 1800 }} 1800w,
                  {{ desk | image_url: width: 2200 }} 2200w,
                  {{ desk | image_url: width: 2800 }} 2800w,
                  {{ desk | image_url: width: 3500 }} 3500w"
                sizes="100vw"
                width="{{ desk.width }}"
                height="{{ desk.height }}"
                alt="{{ d_alt }}"
                {% if forloop.first and s.priority_loading %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
              >
            </picture>
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'rb-slideshow__img rb-slideshow__img--placeholder' }}
          {%- endif -%}
        </div>

        {%- if b.slide_link != blank -%}
          <a class="rb-slideshow__slide-link" href="{{ b.slide_link }}" aria-label="{% if b.heading != blank %}{{ b.heading | escape }}{% else %}{{ 'sections.slideshow.slide' | t | escape }}{% endif %}"></a>
        {%- endif -%}

        <div class="rb-slideshow__inner page-width section-{{ section.id }}-padding">
          <div class="rb-slideshow__content">
            {%- if b.eyebrow != blank -%}
              <p class="rb-slideshow__eyebrow">{{ b.eyebrow }}</p>
            {%- endif -%}

            {%- if b.heading != blank -%}
              <h2 class="rb-slideshow__heading">{{ b.heading }}</h2>
            {%- endif -%}

            {%- if b.body != blank -%}
              <div class="rb-slideshow__body">{{ b.body }}</div>
            {%- endif -%}

            {%- if has_button or has_button_2 -%}
              <div class="rb-slideshow__actions">
                {%- if has_button -%}
                  <a
                    href="{{ b.button_link | default: '#' }}"
                    class="rb-slideshow__cta{% if b.button_style == 'outline' %} rb-slideshow__cta--outline{% endif %}"
                  >
                    {{ b.button_label }}
                    {%- if b.button_arrow -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    {%- endif -%}
                  </a>
                {%- endif -%}

                {%- if has_button_2 -%}
                  <a
                    href="{{ b.button_2_link | default: '#' }}"
                    class="rb-slideshow__cta rb-slideshow__cta--2{% if b.button_2_style == 'outline' %} rb-slideshow__cta--outline{% endif %}"
                  >
                    {{ b.button_2_label }}
                    {%- if b.button_2_arrow -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    {%- endif -%}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if s.show_arrows and slides.size > 1 -%}
    <button type="button" class="rb-slideshow__arrow rb-slideshow__arrow--prev" aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="21" y1="12" x2="4" y2="12"></line><polyline points="11 19 4 12 11 5"></polyline></svg>
    </button>
    <button type="button" class="rb-slideshow__arrow rb-slideshow__arrow--next" aria-label="{{ 'sections.slideshow.next_slideshow' | t }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="12" x2="20" y2="12"></line><polyline points="13 5 20 12 13 19"></polyline></svg>
    </button>
  {%- endif -%}

  {%- if s.show_dots and slides.size > 1 -%}
    <div class="rb-slideshow__dots" role="tablist" aria-label="{{ 'sections.slideshow.carousel' | t }}">
      {%- for block in slides -%}
        <button type="button" class="rb-slideshow__dot{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

<script>
  (function () {
    var root = document.getElementById('{{ uid }}');
    if (!root) return;

    /* ---- Fit to visible viewport (announcement bar + header subtract) ---- */
    if (root.dataset.subtract === 'true') {
      var setOffset = function () {
        var top = root.getBoundingClientRect().top + window.pageYOffset;
        root.style.setProperty('--rb-ss-offset', Math.max(0, Math.round(top)) + 'px');
      };
      setOffset();
      window.addEventListener('resize', setOffset, { passive: true });
      window.addEventListener('load', setOffset);
      if (document.fonts && document.fonts.ready) document.fonts.ready.then(setOffset);
    }

    /* ---- Slideshow ---- */
    var slides = Array.prototype.slice.call(root.querySelectorAll('.rb-slideshow__slide'));
    var dots = Array.prototype.slice.call(root.querySelectorAll('.rb-slideshow__dot'));
    var prevBtn = root.querySelector('.rb-slideshow__arrow--prev');
    var nextBtn = root.querySelector('.rb-slideshow__arrow--next');
    if (slides.length < 2) {
      // Still make sure a lone video plays.
      playVideo(slides[0]);
      return;
    }

    var current = 0;
    var count = slides.length;
    var autoplay = root.dataset.autoplay === 'true';
    var speed = parseInt(root.dataset.speed, 10) || 5000;
    var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var timer = null;

    root.classList.add('rb-slideshow--draggable');

    function playVideo(slide) {
      if (!slide) return;
      var v = slide.querySelector('video');
      if (v) { v.muted = true; var p = v.play(); if (p && p.catch) p.catch(function () {}); }
    }
    function pauseVideo(slide) {
      if (!slide) return;
      var v = slide.querySelector('video');
      if (v) v.pause();
    }

    function goTo(index) {
      index = (index + count) % count;
      if (index === current) return;
      var prevSlide = slides[current];
      slides[current].classList.remove('is-active');
      if (dots[current]) dots[current].classList.remove('is-active');
      pauseVideo(prevSlide);

      current = index;
      slides[current].classList.add('is-active');
      if (dots[current]) dots[current].classList.add('is-active');
      playVideo(slides[current]);
    }

    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    function start() {
      if (!autoplay || reduceMotion) return;
      stop();
      timer = window.setInterval(next, speed);
    }
    function stop() {
      if (timer) { window.clearInterval(timer); timer = null; }
    }
    function restart() { stop(); start(); }

    if (nextBtn) nextBtn.addEventListener('click', function () { next(); restart(); });
    if (prevBtn) prevBtn.addEventListener('click', function () { prev(); restart(); });
    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        goTo(parseInt(dot.dataset.index, 10) || 0);
        restart();
      });
    });

    // Pause auto-rotation while hovering / interacting (but never resume mid-drag).
    function resume() { if (!dragging) start(); }
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', resume);
    root.addEventListener('focusin', stop);
    root.addEventListener('focusout', resume);

    // Pause when the tab is hidden to save resources.
    document.addEventListener('visibilitychange', function () {
      if (document.hidden) stop(); else start();
    });

    // Drag / swipe to change slides — one code path for mouse and touch via
    // Pointer Events.
    var dragId = null, startX = 0, startY = 0, dragging = false, didDrag = false, locked = false;
    var DRAG_THRESHOLD = 60;   // px of travel needed to change slide
    var TAP_SLOP = 6;          // px before a press counts as a drag (suppresses click)

    function onPointerDown(e) {
      if (e.button != null && e.button > 0) return;            // ignore right/middle click
      if (e.target.closest('.rb-slideshow__arrow, .rb-slideshow__cta, .rb-slideshow__dot')) return; // leave controls alone
      dragId = e.pointerId;
      startX = e.clientX; startY = e.clientY;
      dragging = true; didDrag = false; locked = false;
      stop();
      try { root.setPointerCapture(dragId); } catch (err) {}
    }

    function onPointerMove(e) {
      if (!dragging || e.pointerId !== dragId) return;
      var dx = e.clientX - startX;
      var dy = e.clientY - startY;
      // First meaningful move decides intent: a more-vertical gesture is a page
      // scroll, so we bow out and let the browser handle it.
      if (!locked) {
        if (Math.abs(dx) < TAP_SLOP && Math.abs(dy) < TAP_SLOP) return;
        if (Math.abs(dy) > Math.abs(dx)) { dragging = false; return; }
        locked = true; didDrag = true;
        root.classList.add('is-dragging');
      }
    }

    function endDrag(e) {
      if (!dragging && !locked) return;
      var wasLocked = locked;
      var dx = (e.clientX || startX) - startX;
      dragging = false; locked = false;
      try { root.releasePointerCapture(dragId); } catch (err) {}
      root.classList.remove('is-dragging');

      if (wasLocked && Math.abs(dx) > DRAG_THRESHOLD) {
        dx < 0 ? next() : prev();
        restart();
      } else {
        start();
      }
    }

    root.addEventListener('pointerdown', onPointerDown);
    root.addEventListener('pointermove', onPointerMove);
    root.addEventListener('pointerup', endDrag);
    root.addEventListener('pointercancel', endDrag);

    // Swallow the click that a browser fires after a drag, so a dragged
    // slide-link doesn't navigate.
    root.addEventListener('click', function (e) {
      if (didDrag) { e.preventDefault(); e.stopPropagation(); didDrag = false; }
    }, true);

    playVideo(slides[0]);
    start();
  })();
</script>

{% schema %}
{
  "name": "t:sections.rb_slideshow.name",
  "tag": "section",
  "class": "section-rb-slideshow",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "t:sections.rb_slideshow.settings.header_slideshow.content"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:sections.rb_slideshow.settings.autoplay.label",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:sections.rb_slideshow.settings.autoplay_speed.label",
      "min": 3,
      "max": 12,
      "step": 1,
      "unit": "s",
      "default": 6,
      "visible_if": "{{ section.settings.autoplay }}"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "t:sections.rb_slideshow.settings.show_arrows.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "t:sections.rb_slideshow.settings.show_dots.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "priority_loading",
      "label": "t:sections.rb_slideshow.settings.priority_loading.label",
      "info": "t:sections.rb_slideshow.settings.priority_loading.info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.rb_slideshow.settings.header_height.content"
    },
    {
      "type": "select",
      "id": "height",
      "label": "t:sections.rb_slideshow.settings.height.label",
      "options": [
        { "value": "full", "label": "t:sections.rb_slideshow.settings.height.options__full" },
        { "value": "large", "label": "t:sections.rb_slideshow.settings.height.options__large" },
        { "value": "medium", "label": "t:sections.rb_slideshow.settings.height.options__medium" }
      ],
      "default": "full"
    },
    {
      "type": "checkbox",
      "id": "subtract_header",
      "label": "t:sections.rb_slideshow.settings.subtract_header.label",
      "info": "t:sections.rb_slideshow.settings.subtract_header.info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.rb_slideshow.settings.header_layout.content"
    },
    {
      "type": "select",
      "id": "content_vertical",
      "label": "t:sections.rb_slideshow.settings.content_vertical.label",
      "options": [
        { "value": "top", "label": "t:sections.rb_slideshow.settings.content_vertical.options__top" },
        { "value": "center", "label": "t:sections.rb_slideshow.settings.content_vertical.options__center" },
        { "value": "bottom", "label": "t:sections.rb_slideshow.settings.content_vertical.options__bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "t:sections.rb_slideshow.settings.text_align.label",
      "options": [
        { "value": "left", "label": "t:sections.rb_slideshow.settings.text_align.options__left" },
        { "value": "center", "label": "t:sections.rb_slideshow.settings.text_align.options__center" },
        { "value": "right", "label": "t:sections.rb_slideshow.settings.text_align.options__right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "t:sections.rb_slideshow.settings.content_width.label",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 680
    },
    {
      "type": "checkbox",
      "id": "button_full_width_mobile",
      "label": "t:sections.rb_slideshow.settings.button_full_width_mobile.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.rb_slideshow.settings.header_colors.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "paragraph",
      "content": "t:sections.rb_slideshow.settings.color_overrides_info.content"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "t:sections.rb_slideshow.settings.heading_color.label"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.rb_slideshow.settings.text_color.label"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "t:sections.rb_slideshow.settings.button_bg.label"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "t:sections.rb_slideshow.settings.button_text_color.label"
    },
    {
      "type": "color",
      "id": "button_2_bg",
      "label": "t:sections.rb_slideshow.settings.button_2_bg.label"
    },
    {
      "type": "color",
      "id": "button_2_text_color",
      "label": "t:sections.rb_slideshow.settings.button_2_text_color.label"
    },
    {
      "type": "header",
      "content": "t:sections.rb_slideshow.settings.header_overlay.content"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:sections.rb_slideshow.settings.overlay_color.label",
      "default": "#121315"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.rb_slideshow.settings.overlay_opacity.label",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "range",
      "id": "gradient_opacity",
      "label": "t:sections.rb_slideshow.settings.gradient_opacity.label",
      "info": "t:sections.rb_slideshow.settings.gradient_opacity.info",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.rb_slideshow.blocks.slide.name",
      "settings": [
        {
          "type": "header",
          "content": "t:sections.rb_slideshow.blocks.slide.settings.header_media.content"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "t:sections.rb_slideshow.blocks.slide.settings.media_type.label",
          "options": [
            { "value": "image", "label": "t:sections.rb_slideshow.blocks.slide.settings.media_type.options__image" },
            { "value": "video", "label": "t:sections.rb_slideshow.blocks.slide.settings.media_type.options__video" }
          ],
          "default": "image"
        },
        {
          "type": "paragraph",
          "content": "t:sections.rb_slideshow.blocks.slide.settings.image_info.content",
          "visible_if": "{{ block.settings.media_type == 'image' }}"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.rb_slideshow.blocks.slide.settings.image.label",
          "visible_if": "{{ block.settings.media_type == 'image' }}"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "t:sections.rb_slideshow.blocks.slide.settings.image_mobile.label",
          "visible_if": "{{ block.settings.media_type == 'image' }}"
        },
        {
          "type": "select",
          "id": "focal_point",
          "label": "t:sections.rb_slideshow.blocks.slide.settings.focal_point.label",
          "options": [
